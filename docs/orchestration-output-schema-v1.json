{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meridian.local/schemas/training-orchestration-v1.json",
  "title": "Training Orchestration Output V1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "training_orchestration_v1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 90
    },
    "quiz": {
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "correct_index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "question",
          "options",
          "correct_index",
          "explanation"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "title",
    "description",
    "duration_minutes",
    "quiz"
  ]
}
